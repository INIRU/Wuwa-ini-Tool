      "section": "SystemSettings",
      "key": "r.ScreenPercentage",
      "description": {
        "en": "Requests a lower or higher internal render percentage. Lower values may reduce image clarity, and the game may override the value.",
        "ko": "내부 렌더링 비율을 낮추거나 높이도록 요청합니다. 낮은 값은 선명도를 떨어뜨릴 수 있으며 게임이 값을 덮어쓸 수 있습니다."
      },
      "value_type": "integer",
      "constraints": { "minimum": 50, "maximum": 200, "allowed_values": [] },
      "risk": "medium",
      "status": "community_reported",
