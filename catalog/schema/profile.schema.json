{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/INIRU/Wuwa-ini-Tool/catalog/schema/profile.schema.json",
  "title": "Wuwa ini Tool internal custom profile",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "name", "revision", "patch"],
  "properties": {
    "schema_version": { "const": 1 },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_-]{1,64}$",
      "not": { "pattern": "^(con|prn|aux|nul|clock\\$|com[1-9]|lpt[1-9])$" }
    },
    "name": { "type": "string", "minLength": 1, "maxLength": 80 },
    "revision": { "type": "integer", "minimum": 1 },
    "patch": { "$ref": "#/$defs/patch" }
  },
  "$defs": {
    "managed_change": {
      "type": "object",
      "additionalProperties": false,
      "required": ["section", "key", "value"],
      "properties": {
        "section": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[^\\u0000-\\u001F\\u007F]+$" },
        "key": { "type": "string", "minLength": 1, "maxLength": 256, "pattern": "^[^=\\u0000-\\u001F\\u007F]+$" },
        "value": { "type": ["string", "null"], "maxLength": 8192, "pattern": "^[^\\u0000-\\u001F\\u007F]+$" }
      }
    },
    "custom_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["section", "key", "value", "provenance", "runtime_verified"],
      "properties": {
        "section": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[^\\s\\[\\]\\u0000-\\u001F\\u007F](?:[^\\[\\]\\u0000-\\u001F\\u007F]*[^\\s\\[\\]\\u0000-\\u001F\\u007F])?$" },
        "key": { "type": "string", "minLength": 1, "maxLength": 256, "pattern": "^[^\\s=\\u0000-\\u001F\\u007F](?:[^=\\u0000-\\u001F\\u007F]*[^\\s=\\u0000-\\u001F\\u007F])?$" },
        "value": { "type": "string", "minLength": 1, "maxLength": 8192, "pattern": "^[^\\u0000-\\u001F\\u007F]+$" },
        "provenance": { "const": "custom" },
        "runtime_verified": { "const": false }
      }
    },
    "cpu_selection": {
      "oneOf": [
        { "type": "object", "additionalProperties": false, "required": ["mode"], "properties": { "mode": { "const": "all" } } },
        { "type": "object", "additionalProperties": false, "required": ["mode"], "properties": { "mode": { "const": "prefer_performance" } } },
        {
          "type": "object", "additionalProperties": false, "required": ["mode", "ids"],
          "properties": {
            "mode": { "const": "manual_cpu_sets" },
            "ids": { "type": "array", "minItems": 1, "maxItems": 256, "uniqueItems": true, "items": { "type": "integer", "minimum": 0 } }
          }
        },
        {
          "type": "object", "additionalProperties": false, "required": ["mode", "group", "mask"],
          "properties": {
            "mode": { "const": "hard_affinity" },
            "group": { "type": "integer", "minimum": 0, "maximum": 65535 },
            "mask": { "type": "integer", "minimum": 1 }
          }
        }
      ]
    },
    "process": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cpu_selection", "priority"],
      "properties": {
        "cpu_selection": { "$ref": "#/$defs/cpu_selection" },
        "priority": { "enum": ["idle", "below_normal", "normal", "above_normal", "high", "realtime"] }
      }
    },
    "patch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "managed_ini", "custom_ini_entries", "process"],
      "properties": {
        "schema_version": { "const": 1 },
        "managed_ini": { "type": "array", "maxItems": 256, "items": { "$ref": "#/$defs/managed_change" } },
        "custom_ini_entries": { "type": "array", "maxItems": 256, "items": { "$ref": "#/$defs/custom_entry" } },
        "process": { "$ref": "#/$defs/process" }
      }
    }
  }
}
